<%- include('../partials/header') %>
  <div class="book-detail">
    <% if (book.cover_id) { %>
      <img src="/api/covers/<%= book.cover_id %>" alt="<%= book.title %> cover" class="book-cover-large">
    <% } else { %>
      <div class="book-cover-large placeholder">No Cover</div>
    <% } %>
    <div class="book-meta">
      <h2><%= book.title %></h2>
      <h3>by <%= book.author %></h3>
      <div class="rating">
        <% for (let i = 1; i <= 5; i++) { %>
          <span class="star <%= i <= book.rating ? 'filled' : '' %>">★</span>
        <% } %>
      </div>
      <p><strong>Read on:</strong> <%= new Date(book.date_read).toLocaleDateString() %></p>
      <% if (book.notes) { %>
        <div class="notes">
          <h4>Notes:</h4>
          <p><%= book.notes %></p>
        </div>
      <% } %>
      <div class="actions">
        <a href="/books/<%= book.id %>/edit" class="btn">Edit</a>
        <form action="/books/<%= book.id %>?_method=DELETE" method="POST" class="delete-form">
          <button type="submit" class="btn danger">Delete</button>
        </form>
        <a href="/" class="btn">Back to All Books</a>
      </div>
    </div>
  </div>
<%- include('../partials/footer') %>